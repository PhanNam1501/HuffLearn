#define macro MAIN() = takes(0) retuens(0) {
    // Store "Hello, World!" in memory
    0x48656c6c6f2c20576f726c6421        // ["Hello, World!"]
    0x00 mstore

    // Jump to success label, skipping the revert statement
    success             // [success_label_pc, "Hello, World!"]
    jump               // ["Hello, World!"]

    0x00 0x00 revert

    success:
        0x00 mstore
        0x20 0x00 return
}   

